    <ui:VisualElement name="Top" class="FieldBorder FieldBackground Background" style="width: auto; border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px; flex-grow: 0; flex-shrink: 0; height: auto;">
