                <ui:VisualElement picking-mode="Ignore" class="OnFieldIcon" style="width: 15px; height: 15px; background-image: url(&quot;project://database/Packages/com.vulcanus.gameframework.editor/Editor/ExtendEditor/Img/icons/search.png?fileID=2800000&amp;guid=eddb16fcc3e648647b7f246873dd52f3&amp;type=3#search&quot;);" />
