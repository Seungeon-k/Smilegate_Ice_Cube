<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <ui:VisualElement name="titleBar" style="flex-direction: row; background-color: rgb(59, 59, 67); margin-right: 10px; margin-left: 10px; border-top-left-radius: 2px; border-top-right-radius: 2px; border-bottom-right-radius: 2px; border-bottom-left-radius: 2px; flex-grow: 0; align-items: center; height: 26px; min-height: 26px;">
        <ui:VisualElement name="arrowParent" style="height: 16px; width: 16px; min-width: 16px; min-height: 16px; align-items: center; justify-content: center; margin-left: 4px; margin-right: 4px;">
            <ui:VisualElement name="arrowImage" picking-mode="Ignore" style="background-image: url(&quot;project://database/Packages/com.vulcanus.gameframework.editor/Editor/ExtendEditor/Img/icons/arrow_up.png?fileID=2800000&amp;guid=a7298da639fa19748b4827d8a11986b8&amp;type=3#arrow_up&quot;); rotate: 180deg; width: 16px; height: 16px; min-width: 16px; min-height: 16px;" />
        </ui:VisualElement>
