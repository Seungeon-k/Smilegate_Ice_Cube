    <ui:VisualElement name="Top" style="height: 20px; max-height: 20px; min-height: 20px; flex-direction: row; align-items: center; flex-grow: 0;">
        <ui:Label text="0" display-tooltip-when-elided="true" name="index" style="width: 20px; -unity-text-align: upper-center; color: rgb(0, 0, 0);" />
