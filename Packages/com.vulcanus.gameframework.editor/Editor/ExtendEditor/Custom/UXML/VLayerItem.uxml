        <ui:Label text="Default" display-tooltip-when-elided="true" name="LayerName" style="flex-grow: 1; color: rgb(0, 0, 0);" />
        <ui:VisualElement name="Look" style="height: 20px; max-height: 20px; min-height: 20px; min-width: 20px; max-width: 20px; width: 20px; display: none;" />
        <ui:VisualElement name="Click" style="height: 20px; max-height: 20px; min-height: 20px; min-width: 20px; max-width: 20px; width: 20px; display: none;" />
    </ui:VisualElement>
</ui:UXML>
