            <ui:VisualElement style="width: 25px; height: 25px;" />
            <ui:Label text="Label" display-tooltip-when-elided="true" />
            <ui:Button text="Select&#10;" display-tooltip-when-elided="true" style="background-image: none; width: 80px; -unity-text-align: middle-center;" />
