                <ui:VisualElement name="AddStageBt" style="height: 24px; max-height: 24px; min-height: 24px; background-color: rgb(154, 127, 253); width: 120px; border-top-left-radius: 15px; border-top-right-radius: 15px; border-bottom-right-radius: 15px; border-bottom-left-radius: 15px; align-items: center; justify-content: center;">
                    <ui:Label text="+ Add Stage" display-tooltip-when-elided="true" picking-mode="Ignore" name="AddStageBtLB" style="-unity-text-align: middle-left;" />
