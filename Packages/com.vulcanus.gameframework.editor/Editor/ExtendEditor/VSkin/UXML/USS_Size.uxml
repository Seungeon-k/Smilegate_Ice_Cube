                <ui:VisualElement name="FieldLayout" class="FieldLayout">
                    <uie:FloatField value="42.2" name="MaxWidth" class="FloatField" />
                    <ui:DropdownField choices="px,%,none,initial" index="0" name="MaxWidthDropDown" class="DropDown" />
                </ui:VisualElement>
                <ui:VisualElement name="FieldLayout" class="FieldLayout">
                    <uie:FloatField value="42.2" name="MinWidth" class="FloatField" />
                    <ui:DropdownField choices="px,%,Auto,initial" index="0" name="MinWidthDropDown" class="DropDown" />
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="Side3" style="width: 40%; height: 100%;">
                <ui:Label text="Height" display-tooltip-when-elided="true" />
