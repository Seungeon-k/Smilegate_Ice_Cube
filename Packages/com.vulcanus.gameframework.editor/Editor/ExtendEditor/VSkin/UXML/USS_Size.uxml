<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="True">
    <Style src="project://database/Packages/com.vulcanus.gameframework.editor/Editor/ExtendEditor/VSkin/USS/USS_Size.uss?fileID=7433441132597879392&amp;guid=03b1c1f61697b564ea5f93d6eb59ab10&amp;type=3#USS_Size" />
    <ui:VisualElement name="Top" style="flex-direction: column; width: 100%; height: 100%;">
        <ui:VisualElement name="Layout" style="flex-direction: row; width: 100%;">
            <ui:VisualElement name="Side1" style="width: 20%;">
                <ui:Label text="Size" display-tooltip-when-elided="true" style="margin-top: 20px;" />
