                    <uie:FloatField value="42.2" name="Height" class="FloatField" />
                    <ui:DropdownField choices="px,%,Auto,initial" index="0" name="HeightDropDown" class="DropDown" />
                </ui:VisualElement>
                <ui:VisualElement name="FieldLayout" class="FieldLayout">
                    <uie:FloatField value="42.2" name="MaxHeight" class="FloatField" />
                    <ui:DropdownField choices="px,%,none,initial" index="0" name="MaxHeightDropDown" class="DropDown" />
