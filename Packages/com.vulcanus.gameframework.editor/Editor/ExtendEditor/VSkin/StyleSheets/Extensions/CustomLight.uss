
Label{
    color : rgb(65, 65, 65);
}

.AppToolbar{ 
	background-color : rgb(136, 165, 236);
}
.dragtab-label{ 
	background-color : rgb(255, 255, 255);
	border-top-left-radius : 10px;
	border-top-right-radius : 10px;
}
.dragtab first{
    background-color : rgb(255, 255, 255);
    border-top-left-radius : 10px;
    border-top-right-radius : 10px;
}
.AppBackground{ 
	background-color : rgb(106, 143, 231);
}
.OnAppBackgroundIcon{ 
	background-color : rgb(255, 243, 243);
}
.OnAppBackgroundText{ 
	background-color : rgb(255, 243, 243);
}
.WindowBackground{ 
	background-color : rgb(136, 165, 236);
}
.OnWindowBackgroundIcon{ 
	background-color : rgb(136, 165, 236);
}
.WindowContainer{ 
	background-color : rgb(255, 255, 255);
}
.OnWindowContainerText{ 
	color : rgb(65, 65, 65);
	-unity-background-image-tint-color : rgb(65, 65, 65);
}
.OnWindowContainerTextSub{ 
	color : rgb(116, 122, 141);
}
.TabBackground{ 
	background-color : rgb(255, 255, 255);
}
.OnTabText{ 
	color : rgb(88, 95, 188);
}
.OnTabIcon{
    -unity-background-image-tint-color : rgb(88, 95, 188);
}
