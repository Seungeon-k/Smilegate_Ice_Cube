}
.DivideBorder{ 
	background-color : rgb(156, 183, 221);
}
.FieldBackground{ 
	background-color : rgb(255, 255, 255);
}
.FieldBorder{ 
	border-left-color : rgb(176, 224, 255);
	border-right-color : rgb(176, 224, 255);
	border-top-color : rgb(176, 224, 255);
	border-bottom-color : rgb(176, 224, 255);
	border-top-width : 0.5px;
	border-right-width : 0.5px;
	border-bottom-width : 0.5px;
	border-left-width : 0.5px;
}
.OnFieldText{ 
	color : rgb(65, 65, 65);
}
.OnFieldIcon{ 
	-unity-background-image-tint-color : rgb(65, 65, 65);
}
.AddButtonBackground{ 
	background-color : rgb(154, 127, 253);
