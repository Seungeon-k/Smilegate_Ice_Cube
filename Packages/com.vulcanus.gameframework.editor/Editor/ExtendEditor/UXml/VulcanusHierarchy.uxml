                <ui:VisualElement style="flex-direction: row;">
                    <ui:VisualElement name="ObjIconVE" class="SceneItemIcon" style="height: 24px; width: 24px; background-image: url(&quot;project://database/Packages/com.vulcanus.gameframework.editor/Editor/ExtendEditor/Img/icons/tab_scene_dark.png?fileID=2800000&amp;guid=f8013fa4aaadf6b43aae3e38e54fcdab&amp;type=3#tab_scene_dark&quot;); -unity-background-scale-mode: stretch-to-fill; align-items: center; -unity-text-align: middle-left; justify-content: flex-start; min-width: 24px; max-width: 24px; max-height: 24px; min-height: 24px;" />
