            </ui:VisualElement>
            <ui:VisualElement name="PrefabHeadVE" class="SceneItemBackground" style="height: 24px; padding-bottom: 0; flex-direction: row; -unity-text-outline-color: rgb(127, 127, 127); align-items: center; padding-top: 0; margin-bottom: 0; min-height: 24px; max-height: 24px; width: auto; max-width: none; min-width: auto; margin-top: 0; margin-right: 0; margin-left: 0; padding-right: 0; padding-left: 0; justify-content: space-between;">
