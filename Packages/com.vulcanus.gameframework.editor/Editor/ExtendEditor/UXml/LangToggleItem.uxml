<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <ui:VisualElement name="LanguageItem" style="flex-direction: row;">
        <ui:Toggle name="LangCheck" value="false" />
        <ui:Label tabindex="-1" text="Label" parse-escape-sequences="true" display-tooltip-when-elided="true" name="LangName" style="padding-left: 6px;" />
    </ui:VisualElement>
</ui:UXML>
