.VEnumFlagsField {
    flex-direction: row;
    align-items: center;
    height: 22px;
    padding-left: 0;
    padding-right: 0;
    padding-top: 0;
    padding-bottom: 0;
    width: 100%;
}

.VEnumFlagsField > Label {
    width: 35%;
    color: var(--text-primary-default);
    min-width: 35%;
    margin-right: 0;
    margin-top: 0;
    margin-bottom: 0;
    margin-left: 0;
}

.VEnumFlagsField > VisualElement {
    width: 65%;
    height: 18px;
    background-color: var(--original-background-button);
    border-color: var(--background-container-01);
    border-radius: 2px;
    border-width: 1px;
    min-width: 65%;
}
