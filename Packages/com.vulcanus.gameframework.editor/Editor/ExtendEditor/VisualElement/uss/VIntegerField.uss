.VIntegerField {
    height: 22px;
    flex-direction: row;
    align-items: center;
    padding: 0;
    font-size: 12px;
    width: 100%;
}

.VIntegerField > Label {
    width: 35%;
    min-width: 35%;
    font-size: 12px;
    color: var(--text-primary-default);
    margin-right: 0;
    margin-top: 0;
    margin-bottom: 0;
    margin-left: 0;
}

.child .VIntegerField > Label {
    padding-left: 6px;
    -unity-text-align: middle-left;
    width: 35%;
    min-width: 35%;
    margin-right: 0;
    margin-top: 0;
    margin-bottom: 0;
    margin-left: 0;
}

.VIntegerField > #unity-text-input {
    width: 65%;
    background-color: var(--original-background-field);
    border-color: var(--background-container-01);
    height: 18px;
    justify-content: flex-start;
    border-radius: 2px;
    border-width: 1px;
    min-width: 65%;
}

.VIntegerField > #unity-text-input > TextElement {
    font-size: 12px;
    color: var(--text-primary-default);
    height: auto;
}
