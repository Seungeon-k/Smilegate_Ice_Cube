.VVector2IntField {
    flex-direction: row;
    align-items: center;
    height: 22px;
    padding-left: 0;
    padding-right: 0;
    padding-top: 3px;
    padding-bottom: 3px;
    width: 100%;
}

.VVector2IntField > Label {
    width: 35%;
    color: var(--text-primary-default);
    min-width: 35%;
    margin-right: 0;
    margin-top: 0;
    margin-bottom: 0;
    margin-left: 0;
    text-overflow: ellipsis;
}

.child .VVector2IntField > Label {
    padding-left: 6px;
    width: 35%;
    min-width: 35%;
    margin-right: 0;
    margin-top: 0;
    margin-bottom: 0;
    margin-left: 0;
    text-overflow: ellipsis;
}

.VVector2IntField > VisualElement {
    width: 65%;
    flex-direction: row;
    height: 18px;
    min-width: 65%;
}

.VVector2IntField > VisualElement > #unity-x-input > Label {
    font-size: 12px;
    color: var(--Vector-x-color);
    -unity-text-align: middle-left;
}

.VVector2IntField > VisualElement > #unity-x-input > #unity-text-input {
    background-color: var(--original-background-field);
    border-color: var(--background-container-01);
    height: 18px;
}

.VVector2IntField > VisualElement > #unity-x-input > #unity-text-input > TextElement {
    font-size: 12px;
    color: var(--text-primary-default);
    height: 18px;
}

.VVector2IntField > VisualElement > #unity-y-input > Label {
    font-size: 12px;
    color: var(--text-primary-default);
    -unity-text-align: middle-left;
}

.VVector2IntField > VisualElement > #unity-y-input > #unity-text-input {
    background-color: var(--original-background-field);
    border-color: var(--background-container-01);
    height: 18px;
}

.VVector2IntField > VisualElement > #unity-y-input > #unity-text-input > TextElement {
    font-size: 12px;
    color: var(--text-primary-default);
}
