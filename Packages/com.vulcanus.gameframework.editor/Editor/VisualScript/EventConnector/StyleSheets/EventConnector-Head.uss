
.gc-list-item-head-running > .gc-list-item-head .gc-list-item-head-info {
    border-left-color: var(--gc-color-border-active);
    border-left-width: 5px;
    background-color: var(--gc-color-list-head-running);
}

.gc-list-item-head .gc-list-item-head-info--EventConnector {
    background-color: var(--vs-color-list-head-EventConnector);
    color: var(--vs-color-list-head-EventConnector-label);
}