Button{
    width: 30px;
    height: 30px;
    padding-left: 0;
    padding-right: 0;
    padding-top: 0;
    padding-bottom: 0;
    margin-left: 0;
    margin-right:0;
    margin-top: 0;
    margin-bottom: 0;
    border-right-width: 0px;
    border-bottom-left-radius: 3px;
    -unity-slice-right: 0;
    border-left-width: 0px;
    border-top-width: 0px;
    border-bottom-width: 0px;
    background-color: rgba(0, 0, 0, 0);
     -unity-background-scale-mode: scale-to-fit; 
}